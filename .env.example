# RSS News Intelligence Configuration
# Copy this file to .env and modify as needed
# 复制此文件为 .env 并按需修改

# Admin password for feed management / 数据源管理密码
ADMIN_TOKEN=admin@2026

# Server port / 服务端口
# PORT=37378

# Database path / 数据库路径
# DB_PATH=data/rss_news.db

# RSS refresh interval in seconds / RSS 刷新间隔（秒）
# REFRESH_INTERVAL=300
